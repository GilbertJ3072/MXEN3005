<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE xml>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="wx250s">

  <xacro:property name="L1" value="1.1025" />
  <xacro:property name="L1radius" value="0.80" />
  <xacro:property name="L2_1" value="2.50" />
  <xacro:property name="L2_1radius" value="0.20" />
  <xacro:property name="L2_2" value="0.50" />
  <xacro:property name="L2_2radius" value="0.20" />
  <xacro:property name="L3" value="1.7155" />
  <xacro:property name="L3radius" value="0.20" />
  <xacro:property name="L4" value="0.7845" />
  <xacro:property name="L4radius" value="0.25" />
  <xacro:property name="L5" value="0.65" />
  <xacro:property name="L5radius" value="0.15" />
  <xacro:property name="L6" value="1.0915" />
  <xacro:property name="L6radius" value="0.25" />
  <xacro:property name="eex" value="0.5" />
  <xacro:property name="eey" value="0.2" />
  <xacro:property name="eez" value="0.2" />
  <xacro:property name="eeoffset" value="0.35"/>

  <xacro:property name="J1MIN" value="${-pi}" />
  <xacro:property name="J1MAX" value="${pi}" />
  <xacro:property name="J2MIN" value="-1.88" />
  <xacro:property name="J2MAX" value="1.99" />
  <xacro:property name="J3MIN" value="-2.15" />
  <xacro:property name="J3MAX" value="1.61" />
  <xacro:property name="J4MIN" value="${-pi}" />
  <xacro:property name="J4MAX" value="${pi}" />
  <xacro:property name="J5MIN" value="-1.75" />
  <xacro:property name="J5MAX" value="2.15" />
  <xacro:property name="J6MIN" value="${-pi}" />
  <xacro:property name="J6MAX" value="${pi}" />

  <material name="blue">
    <color rgba="0.2 0.4 0.65 1" />
  </material>

  <material name="yellow">
    <color rgba="1 0.85 0 1" />
  </material>

  <link name="world" />

  <link name="base" />

  <link name="link1">
    <visual name="link1">
      <origin xyz="0 0 ${L1/2}" />
      <geometry>
        <cylinder radius="${L1radius}" length="${L1}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link2_1">
    <visual name="link2_1">
      <origin xyz="0 0 ${L2_1/2}" />
      <geometry>
        <box size="${L2_1radius} ${L2_1radius} ${L2_1}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link2_2">
    <visual name="link2_2">
      <origin xyz="${L2_2/2} 0 0" />
      <geometry>
        <box size="${L2_2} ${L2_2radius} ${L2_2radius}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link3">
    <visual name="link3">
      <origin xyz="${L3/2} 0 0" />
      <geometry>
        <box size="${L3} ${L3radius} ${L3radius}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link4">
    <visual name="link4">
      <origin xyz="${L4/2} 0 0" />
      <geometry>
        <box size="${L4} ${L4radius} ${L4radius}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link5">
    <visual name="link5">
      <origin xyz="${L5/2} 0 0" />
      <geometry>
        <box size="${L5} ${L5radius} ${L5radius}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="link6">
    <visual name="link6">
      <origin xyz="${L6/2} 0 0" />
      <geometry>
        <box size="${L6} ${L6radius} ${L6radius}" />
      </geometry>
      <material name="blue" />
    </visual>
  </link>

  <link name="ee_l">
    <visual name="ee_l">
      <origin xyz="${eex/2} 0 0" />
      <geometry>
        <box size="${eex} ${eey} ${eez}" />
      </geometry>
      <material name="yellow" />
    </visual>
  </link>

  <link name="ee_r">
    <visual name="ee_r">
      <origin xyz="${eex/2} 0 0" />
      <geometry>
        <box size="${eex} ${eey} ${eez}" />
      </geometry>
      <material name="yellow" />
    </visual>
  </link>

  <joint name="base_in_world" type="fixed">
    <parent link="world" />
    <child link="base" />
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="joint1" type="revolute">
    <parent link="base" />
    <child link="link1" />
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="${J1MIN}" upper="${J1MAX}" effort="1" velocity="1" />
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="link1" />
    <child link="link2_1" />
    <origin xyz="0 0 ${L1}" rpy="0 0 0" />
    <axis xyz="0 -1 0" />
    <limit lower="${J2MIN}" upper="${J2MAX}" effort="1" velocity="1" />
  </joint>

  <joint name="jointI" type="fixed">
    <parent link="link2_1" />
    <child link="link2_2" />
    <origin xyz="0 0 ${L2_1}" rpy="0 0 0" />
  </joint>

  <joint name="joint3" type="revolute">
    <parent link="link2_2" />
    <child link="link3" />
    <origin xyz="${L2_2} 0 0" rpy="0 0 0" />
    <axis xyz="0 -1 0" />
    <limit lower="${J3MIN}" upper="${J3MAX}" effort="1" velocity="1" />
  </joint>

  <joint name="joint4" type="revolute">
    <parent link="link3" />
    <child link="link4" />
    <origin xyz="${L3} 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="${J4MIN}" upper="${J4MAX}" effort="1" velocity="1" />
  </joint>

  <joint name="joint5" type="revolute">
    <parent link="link4" />
    <child link="link5" />
    <origin xyz="${L4} 0 0" rpy="0 0 0" />
    <axis xyz="0 -1 0" />
    <limit lower="${J5MIN}" upper="${J5MAX}" effort="1" velocity="1" />
  </joint>

  <joint name="joint6" type="revolute">
    <parent link="link5" />
    <child link="link6" />
    <origin xyz="${L5} 0 0" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="${J6MIN}" upper="${J6MAX}" effort="1" velocity="1" />
  </joint>

  <joint name="joint_ee_l" type="prismatic">
    <parent link="link6" />
    <child link="ee_l" />
    <origin xyz="${L6} ${eeoffset} 0" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit lower="-${eeoffset-eey/2}" upper="0" effort="1" velocity="1" />
  </joint>

  <joint name="joint_ee_r" type="prismatic">
    <parent link="link6" />
    <child link="ee_r" />
    <origin xyz="${L6} -${eeoffset} 0" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit lower="0" upper="${eeoffset - eey/2}" effort="1" velocity="1" />
  </joint>

</robot>
